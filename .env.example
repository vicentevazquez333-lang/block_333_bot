# Variables de entorno del bot
# Copia este archivo como .env y completa los valores

# Token del bot (lo da @BotFather en Telegram)
TELEGRAM_TOKEN=8617966761:AAEu-DoargseqjW1l74cMuluQJhjaE71D7g

# Solo estos user_id de Telegram pueden usar el bot (coma separada). Vacío = abierto a todos.
# Tu ID: @userinfobot o @RawDataBot
# TELEGRAM_ALLOWED_USER_IDS=123456789

# Credenciales de la API de cedula.com.ve
# Regístrate gratis en: https://cedula.com.ve/web/login.php
API_APP_ID=tu_app_id_aqui
API_TOKEN=tu_token_api_aqui

# URL pública de tu deployment (Koyeb/Render te la da automáticamente)
# Ejemplo Koyeb:  https://mi-bot-abc123.koyeb.app
# Ejemplo Render: https://mi-bot.onrender.com
# Para desarrollo local: deja esta línea vacía o bórrala
WEBHOOK_URL=https://TU-APP.koyeb.app

# Opcional: ruta absoluta al digitel.sqlite (por defecto: BASE DE DATOS/digitel.sqlite)
# DIGITEL_DB=D:/ruta/completa/digitel.sqlite

# Opcional: si el .sqlite no existe, se descarga una vez desde esta URL (ej. Supabase Storage público)
# En Render suele combinarse con DIGITEL_DB=/tmp/digitel.sqlite
# DIGITEL_DOWNLOAD_URL=https://xxxx.supabase.co/storage/v1/object/public/BUCKET/digitel.sqlite
# Si la URL es privada (p. ej. GitHub Release en repo privado), PAT con lectura de repo:
# DIGITEL_DOWNLOAD_TOKEN=ghp_xxxxxxxx
# Otros servicios con Bearer: DIGITEL_DOWNLOAD_AUTH=bearer

# ── Base GNB (importar con: python import_gnb_sqlite.py) ──────────────────
# En Render, igual que Digitel: sube gnb.sqlite a un Release y usa ruta en /tmp
# GNB_DB=/tmp/gnb.sqlite
# GNB_DOWNLOAD_URL=https://github.com/TU_USUARIO/TU_REPO/releases/download/TU_TAG/gnb.sqlite
# (Nunca uses /releases/tag/… — eso es HTML, no el archivo .sqlite)
# GNB_DOWNLOAD_TOKEN=ghp_xxxxxxxx
# GNB_DOWNLOAD_AUTH=bearer

# ── Exportar historial del chat a PDF (/exportar_chat) ─────────────────────
# SQLite local donde se guardan mensajes de texto (por defecto BASE DE DATOS/chat_log.sqlite).
# En Render suele usarse: CHAT_LOG_DB=/tmp/chat_log.sqlite
# CHAT_LOG_DB=/tmp/chat_log.sqlite
# Máximo de líneas guardadas por chat (por defecto 8000)
# CHAT_EXPORT_MAX_LINES=8000
